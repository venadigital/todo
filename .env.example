# Frontend
VITE_STATE_ENDPOINT=/api/state
VITE_REMOTE_SYNC=true

# Backend
PORT=8787

# Storage mode: mysql | file
STORAGE_DRIVER=mysql

# MySQL (Hostinger)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=todo_board
DB_SSL=false
DB_POOL_SIZE=8

# File fallback (only when STORAGE_DRIVER=file)
DATA_FILE=./data/todo-board-state.json
